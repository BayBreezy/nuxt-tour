{
  "name": "nuxt-tour",
  "version": "0.0.40",
  "description": "Empower your users with interactive guided tours of your Nuxt applications using the nuxt-tour module. With this module, developers can seamlessly integrate step-by-step tooltips into their applications, providing clear instructions and highlighting key features.",
  "license": "MIT",
  "author": {
    "name": "Behon Baker",
    "email": "behon.baker@yahoo.com",
    "url": "https://behonbaker.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BayBreezy/nuxt-tour.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "scripts": {
    "automd:docs": "nlx automd@latest --dir docs/content --input '**/*.md' --watch",
    "clean": "node ./scripts/clean.mjs",
    "dev": "nr dev:prepare && cd docs && nr dev",
    "dev:build": "cd docs && nr build",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare",
    "fix": "nr lint:fix && nr fmt && nr test && nr automd:docs",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "netlify": "nr prepack && npm run dev:build",
    "prepack": "nuxt-module-build build",
    "prepare": "nr dev:prepare && bun run --cwd docs prepare",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "rm:lock": "rm -rf package-lock.json playground/package-lock.json",
    "test": "vitest run",
    "test:types": "vue-tsc --noEmit && cd docs && vue-tsc --noEmit",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@nuxt/icon": "^2.2.2",
    "@nuxt/kit": "^4.4.4",
    "@popperjs/core": "^2.11.8",
    "@types/jump.js": "^1.0.6",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "focus-trap": "^8.2.0",
    "jump.js": "^1.0.2"
  },
  "devDependencies": {
    "@antfu/ni": "^30.1.0",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.4",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^25.6.0",
    "changelogen": "^0.6.2",
    "nuxt": "^4.4.4",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  },
  "lint-staged": {
    "*.{js,ts,vue,css,mjs,cjs}": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "nr lint"
  },
  "packageManager": "bun@1.3.9",
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild"
  ]
}
